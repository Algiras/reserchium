# Example configuration for a generic OpenAI-compatible API Provider (or standard OpenAI)
API_KEY=your_api_key_here
# Uncomment and set this to use a custom provider host url (e.g. vLLM, LMStudio, any OpenAI-compatible endpoint)
# API_BASE_URL=https://api.yourprovider.com/v1

# Optional: Brave Search API Key for the 'agent' web search command
BRAVE_API_KEY=your_brave_search_api_key

# Optional: Semantic Scholar API Key for premium fetching via 'fetch --provider semanticscholar'
SEMANTICSCHOLAR_API_KEY=your_semanticscholar_api_key

# Optional: LlamaParse API Key for advanced PDF extraction (math, tables)
LLAMAPARSE_API_KEY=your_llamaparse_api_key
